{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://res.cloudinary.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://res.cloudinary.com https://unware.studio; connect-src 'self'; frame-ancestors 'none';"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "nexa-neon.vercel.app"}],
      "destination": "https://unware.studio/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{"type": "header", "key": "x-forwarded-proto", "value": "http"}],
      "destination": "https://unware.studio/$1",
      "permanent": true
    },
    {
      "source": "/Support/faq.html",
      "destination": "/Support/FAQ.html",
      "permanent": true
    },
    {
      "source": "/Support/support.html",
      "destination": "/Support/centre-aide.html",
      "permanent": true
    }
  ]
}
