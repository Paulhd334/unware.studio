{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{"type": "host", "value": "nexa-neon.vercel.app"}],
      "destination": "https://unware.studio/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{"type": "header", "key": "x-forwarded-proto", "value": "http"}],
      "destination": "https://unware.studio/$1",
      "permanent": true
    },
    {
      "source": "/Support/faq.html",
      "destination": "/Support/FAQ.html",
      "permanent": true
    },
    {
      "source": "/Support/support.html",
      "destination": "/Support/centre-aide.html",
      "permanent": true
    }
  ]
}
