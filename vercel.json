{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/Support/faq.html",
      "destination": "/Support/FAQ.html",
      "permanent": true
    },
    {
      "source": "/Support/support.html",
      "destination": "/Support/centre-aide.html",
      "permanent": true
    }
  ]
}
